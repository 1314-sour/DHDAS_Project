<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DHDAS.App.Shell.ViewModels"
        x:Class="DHDAS.App.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DHDAS 插件宿主外壳" Width="800" Height="450">
    
   <Grid ColumnDefinitions="200, *">
        <!-- 左侧菜单栏 -->
        <Border Grid.Column="0" Background="#2b2b2b">
            <StackPanel>
                <TextBlock Text="功能模块" Foreground="White" Margin="10" FontWeight="Bold"/>
                <ListBox ItemsSource="{Binding Plugins}" 
                         SelectedItem="{Binding SelectedPlugin}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 右侧内容插槽 -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="10"/>
    </Grid>
</Window>